# ── Server (Express) ──────────────────────────────────────────────────────────
PORT=3000

# ── Slack ─────────────────────────────────────────────────────────────────────
# From your Slack app settings (api.slack.com/apps → Basic Information)
SLACK_SIGNING_SECRET=

# Bot User OAuth Token (api.slack.com/apps → OAuth & Permissions)
# Starts with xoxb-
SLACK_BOT_TOKEN=

# Set to "true" in local dev to skip signature verification
# SLACK_SKIP_VERIFICATION=true

# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT with Contents: Read on your repos
GITHUB_TOKEN=

# ── AI Provider ──────────────────────────────────────────────────────────────
# Google AI Studio key (aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_API_KEY=

# ── Trigger.dev ──────────────────────────────────────────────────────────────
# From your Trigger.dev dashboard
TRIGGER_SECRET_KEY=
